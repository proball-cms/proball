<body class="bg-background text-on-background min-h-screen flex flex-col">

<!-- NAV -->
<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="/index.html" class="flex-shrink-0">
      <img
        src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg"
        alt="ProBall"
        class="h-12 w-auto object-contain"
      />
    </a>
    <div class="hidden md:flex flex-1 items-center justify-center space-x-8">
      <a href="/index.html"       class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="/locations.html"   class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Programs &amp; Locations</a>
      <a href="/schedule.html"    class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="/blog/index.html"  class="text-primary font-bold border-b-2 border-primary pb-0.5">Blog</a>
    </div>
    <div class="flex items-center gap-sm">
      <a href="tel:0406974582" class="hidden sm:inline-flex items-center gap-1 text-tertiary hover:text-primary font-body-md text-sm font-medium transition-colors" aria-label="Call ProBall">
        <span class="material-symbols-outlined text-base">call</span>
        0406 974 582
      </a>
      <a href="/how-to-join.html#register"
         class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">
        Book a Free Trial
      </a>
      <button
        id="nav-toggle"
        class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors"
        aria-label="Open menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="/index.html"       class="block text-slate-600 font-medium hover:text-primary transition-colors">Home</a>
    <a href="/locations.html"   class="block text-slate-600 font-medium hover:text-primary transition-colors">Programs &amp; Locations</a>
    <a href="/schedule.html"    class="block text-slate-600 font-medium hover:text-primary transition-colors">Schedule</a>
    <a href="/blog/index.html"  class="block text-primary font-bold">Blog</a>
  </div>
</header>

<script>
  document.getElementById('nav-toggle').addEventListener('click', function() {
    document.getElementById('mobile-menu').classList.toggle('open');
  });
</script>

<main class="flex-grow">

  <!-- HERO -->
  <section class="relative py-6 md:py-14 flex items-center overflow-hidden bg-[#004aad]">
    <div class="max-w-7xl mx-auto px-6 w-full">
      <span class="inline-block bg-primary text-on-primary font-label-lg text-label-lg uppercase rounded-full px-4 py-1 mb-3 md:mb-4">
        ProBall Blog
      </span>
      <h1 class="font-display-lg text-[32px] sm:text-[44px] md:text-display-lg text-white uppercase leading-[0.95] mb-2 md:mb-3">
        Insights &amp; News
      </h1>
      <p class="font-body-md md:font-body-lg text-body-md md:text-body-lg text-slate-300 max-w-xl">
        Coaching philosophy, player development, and everything Sydney basketball.
      </p>
    </div>
  </section>

  {% if collections.posts.length > 0 %}
  {% set featuredPost = collections.posts[0] %}

  <!-- FEATURED POST -->
  <section class="max-w-7xl mx-auto px-6 pt-6 pb-md md:pt-lg">
    <h2 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-3 md:mb-4">Latest Post</h2>

    {% if featuredPost.data.category in ["Coaching", "News", "Parenting & Sport", "Mindset"] %}
      {% set featuredBadgeClass = "bg-primary text-on-primary" %}
    {% else %}
      {% set featuredBadgeClass = "bg-secondary text-white" %}
    {% endif %}

    <a href="{{ featuredPost.url }}"
       class="post-card block rounded-2xl overflow-hidden bg-white shadow-md border border-slate-100 group">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="relative min-h-36 md:min-h-64 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-[#004aad]/40 to-transparent z-10"></div>
          <img
            src="{{ featuredPost.data.image if featuredPost.data.image[0] == '/' else '/images/' + featuredPost.data.image }}"
            alt="{{ featuredPost.data.imageAlt }}"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="object-position: {{ featuredPost.data.imagePosition }}"
          />
          <span class="absolute top-4 left-4 z-20 {{ featuredBadgeClass }} font-label-lg text-label-lg uppercase rounded-full px-3 py-0.5">
            {{ featuredPost.data.category }}
          </span>
        </div>
        <div class="p-5 md:p-8 flex flex-col justify-center">
          <p class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-2 md:mb-3">{{ featuredPost.date | readableDate }}</p>
          <h3 class="font-headline-lg text-2xl md:text-headline-lg text-on-background mb-3 md:mb-4 group-hover:text-primary transition-colors leading-tight">
            {{ featuredPost.data.title }}
          </h3>
          <p class="font-body-md text-body-md text-slate-600 leading-relaxed mb-6">
            {{ featuredPost.data.description }}
          </p>
          <span class="inline-flex items-center gap-2 text-primary font-medium text-sm group-hover:gap-3 transition-all">
            Read article
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- POST GRID -->
  <section class="max-w-7xl mx-auto px-6 pb-xl">
    <h2 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-6">More Posts</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">

      {% for post in collections.posts %}
      {% if loop.index0 > 0 %}

      {% if post.data.category in ["Coaching", "News", "Parenting & Sport", "Mindset"] %}
        {% set badgeClass = "bg-primary text-on-primary" %}
      {% else %}
        {% set badgeClass = "bg-secondary text-white" %}
      {% endif %}

      <a href="{{ post.url }}"
         class="post-card block rounded-xl overflow-hidden bg-white shadow-sm border border-slate-100 group flex flex-col">
        <div class="relative h-48 overflow-hidden">
          <div class="absolute inset-0 bg-[#004aad]/20 z-10"></div>
          <img
            src="{{ post.data.image if post.data.image[0] == '/' else '/images/' + post.data.image }}"
            alt="{{ post.data.imageAlt }}"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="object-position: {{ post.data.imagePosition }}"
          />
          <span class="absolute top-3 left-3 z-20 {{ badgeClass }} font-label-lg text-label-lg uppercase rounded-full px-3 py-0.5 text-xs">
            {{ post.data.category }}
          </span>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <p class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider text-xs mb-2">{{ post.date | readableDate }}</p>
          <h3 class="font-headline-md text-headline-md text-on-background mb-3 group-hover:text-primary transition-colors leading-snug">
            {{ post.data.title }}
          </h3>
          <p class="font-body-md text-body-md text-slate-600 text-sm leading-relaxed mb-4 flex-grow">
            {{ post.data.description }}
          </p>
          <span class="inline-flex items-center gap-1.5 text-primary font-medium text-sm group-hover:gap-2.5 transition-all">
            Read more <span class="material-symbols-outlined text-base">arrow_forward</span>
          </span>
        </div>
      </a>

      {% endif %}
      {% endfor %}

      <!-- CTA card -->
      <div class="rounded-xl overflow-hidden bg-primary flex flex-col items-center justify-center p-8 text-center">
        <span class="material-symbols-outlined text-white text-5xl mb-4">sports_basketball</span>
        <h3 class="font-headline-md text-headline-md text-white mb-3">Ready to play?</h3>
        <p class="font-body-md text-body-md text-white/80 mb-6 text-sm leading-relaxed">
          Stop reading — come and see what ProBall is all about. Book a free trial session today.
        </p>
        <a href="/how-to-join.html#register"
           class="inline-block bg-white text-primary font-button text-button px-6 py-2.5 rounded-full hover:scale-105 active:scale-95 transition-all shadow-sm">
          Book a Free Trial
        </a>
      </div>

    </div>
  </section>
  {% endif %}

  <!-- NEWSLETTER STRIP -->
  <section class="bg-secondary text-white">
    <div class="max-w-7xl mx-auto px-6 py-md">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-headline-md text-headline-md text-white mb-1">Get new posts in your inbox</h3>
          <p class="font-body-md text-body-md text-white/70">Coaching tips, season news, and player development insights.</p>
        </div>
        <div class="flex gap-2 w-full md:w-auto md:min-w-96">
          <input
            type="email"
            placeholder="Your email address"
            class="bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white text-sm focus:ring-2 focus:ring-white/50 w-full placeholder-white/50 outline-none"
          />
          <button class="bg-primary text-on-primary px-5 py-3 rounded-lg font-button hover:bg-primary-container transition-colors flex-shrink-0">
            Subscribe
          </button>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- FOOTER -->
<footer class="bg-[#004aad] border-t-4 border-primary w-full py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div class="flex flex-col">
      <div class="bg-white rounded-lg px-3 py-2 inline-block self-start mb-4"><img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-8 w-auto object-contain"/></div>
      <p class="font-body-md text-sm text-slate-300 mb-6 leading-relaxed">Developing the next generation of Australian basketball talent through elite coaching, structured development, and a love for the game.</p>
