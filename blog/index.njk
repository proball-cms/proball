  <meta name="description" content="Basketball tips, coaching insights and player development articles from the ProBall team. Resources for parents and junior athletes in Sydney."/>
  <meta name="robots" content="noindex, nofollow"/>
  <link rel="canonical" href="https://proball.com/blog/"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet"/>
