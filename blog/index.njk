          <li><a href="/schedule.html"   class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Schedule</a></li>
          <li><a href="/blog/index.html" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/how-to-join.html#register" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">How to Join</a></li>
