<!DOCTYPE html>
<html class="light" lang="en-AU">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>Basketball Blog | ProBall Sydney Youth Basketball</title>
  <meta name="description" content="Basketball tips, coaching insights and player development articles from the ProBall team. Resources for parents and junior athletes in Sydney."/>
  <meta name="robots" content="noindex, nofollow"/>
  <link rel="canonical" href="https://proball.com/blog/"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-variant":           "#e4e2e1",
            "surface-tint":              "#c0030a",
            "secondary":                 "#4c5b95",
            "surface-container-lowest":  "#ffffff",
            "tertiary":                  "#5b5c5c",
            "surface":                   "#fbf9f8",
            "surface-dim":               "#dcd9d9",
            "on-background":             "#1b1c1c",
            "inverse-primary":           "#ffb4a9",
            "surface-container-low":     "#f6f3f2",
            "outline-variant":           "#e6bdb7",
            "surface-container-highest": "#e4e2e1",
            "surface-container-high":    "#eae8e7",
            "secondary-fixed-dim":       "#b7c4ff",
            "secondary-fixed":           "#dce1ff",
            "on-secondary":              "#ffffff",
            "primary":                   "#bc0008",
            "primary-fixed-dim":         "#ffb4a9",
            "inverse-surface":           "#303030",
            "primary-container":         "#e12720",
            "secondary-container":       "#afbefe",
            "surface-container":         "#f0eded",
            "on-surface-variant":        "#5d3f3b",
            "on-surface":                "#1b1c1c",
            "on-secondary-fixed":        "#02164e",
            "on-secondary-container":    "#3d4c84",
            "on-primary":                "#ffffff",
            "background":                "#fbf9f8",
            "primary-fixed":             "#ffdad5",
            "on-primary-container":      "#fffbff",
            "inverse-on-surface":        "#f3f0f0"
          },
          borderRadius: {
            "DEFAULT": "0.25rem",
            "lg":      "0.5rem",
            "xl":      "0.75rem",
            "full":    "9999px"
          },
          spacing: {
            "xs":     "4px",
            "sm":     "12px",
            "base":   "8px",
            "md":     "24px",
            "lg":     "48px",
            "xl":     "80px",
            "gutter": "24px"
          },
          fontFamily: {
            "display-lg":  ["Lexend", "sans-serif"],
            "headline-lg": ["Lexend", "sans-serif"],
            "headline-md": ["Lexend", "sans-serif"],
            "body-lg":     ["Lexend", "sans-serif"],
            "body-md":     ["Lexend", "sans-serif"],
            "label-lg":    ["Lexend", "sans-serif"],
            "button":      ["Lexend", "sans-serif"]
          },
          fontSize: {
            "display-lg":  ["48px",  { lineHeight: "56px",  letterSpacing: "-0.02em", fontWeight: "800" }],
            "headline-lg": ["32px",  { lineHeight: "40px",  letterSpacing: "-0.01em", fontWeight: "700" }],
            "headline-md": ["24px",  { lineHeight: "32px",  fontWeight: "700" }],
            "body-lg":     ["18px",  { lineHeight: "28px",  fontWeight: "400" }],
            "body-md":     ["16px",  { lineHeight: "24px",  fontWeight: "400" }],
            "label-lg":    ["14px",  { lineHeight: "20px",  letterSpacing: "0.05em", fontWeight: "600" }],
            "button":      ["16px",  { lineHeight: "20px",  fontWeight: "700" }]
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Lexend', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }
    .post-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .post-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.10);
    }
  </style>
</head>
<body class="bg-background text-on-background min-h-screen flex flex-col">

<!-- NAV -->
<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="/index.html" class="flex-shrink-0">
      <img
        src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg"
        alt="ProBall"
        class="h-12 w-auto object-contain"
      />
    </a>
    <div class="hidden md:flex items-center space-x-8">
      <a href="/index.html"       class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="/locations.html"   class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Programs &amp; Locations</a>
      <a href="/schedule.html"    class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="/team.html"        class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Our Team</a>
      <a href="/blog/index.html"  class="text-primary font-bold border-b-2 border-primary pb-0.5">Blog</a>
      <a href="/how-to-join.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">How to Join</a>
    </div>
    <div class="flex items-center gap-sm">
      <a href="/how-to-join.html"
         class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">
        Book a Free Trial
      </a>
      <button
        id="nav-toggle"
        class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors"
        aria-label="Open menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="/index.html"       class="block text-slate-600 font-medium hover:text-primary transition-colors">Home</a>
    <a href="/locations.html"   class="block text-slate-600 font-medium hover:text-primary transition-colors">Programs &amp; Locations</a>
    <a href="/schedule.html"    class="block text-slate-600 font-medium hover:text-primary transition-colors">Schedule</a>
    <a href="/team.html"        class="block text-slate-600 font-medium hover:text-primary transition-colors">Our Team</a>
    <a href="/blog/index.html"  class="block text-primary font-bold">Blog</a>
    <a href="/how-to-join.html" class="block text-slate-600 font-medium hover:text-primary transition-colors">How to Join</a>
  </div>
</header>

<script>
  document.getElementById('nav-toggle').addEventListener('click', function() {
    document.getElementById('mobile-menu').classList.toggle('open');
  });
</script>

<main class="flex-grow">

  <!-- HERO -->
  <section class="relative h-56 md:h-64 flex items-center overflow-hidden bg-slate-900">
    <div class="max-w-7xl mx-auto px-6 w-full">
      <span class="inline-block bg-primary text-on-primary font-label-lg text-label-lg uppercase rounded-full px-4 py-1 mb-4">
        ProBall Blog
      </span>
      <h1 class="font-display-lg text-display-lg text-white uppercase leading-[0.95] mb-3">
        Insights &amp; News
      </h1>
      <p class="font-body-lg text-body-lg text-slate-300 max-w-xl">
        Coaching philosophy, player development, and everything Sydney basketball.
      </p>
    </div>
  </section>

  {% if collections.posts.length > 0 %}
  {% set featuredPost = collections.posts[0] %}

  <!-- FEATURED POST -->
  <section class="max-w-7xl mx-auto px-6 pt-lg pb-md">
    <h2 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-4">Latest Post</h2>

    {% if featuredPost.data.category in ["Coaching", "News", "Parenting & Sport", "Mindset"] %}
      {% set featuredBadgeClass = "bg-primary text-on-primary" %}
    {% else %}
      {% set featuredBadgeClass = "bg-secondary text-white" %}
    {% endif %}

    <a href="{{ featuredPost.url }}"
       class="post-card block rounded-2xl overflow-hidden bg-white shadow-md border border-slate-100 group">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="relative h-48 md:h-64 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-slate-900/40 to-transparent z-10"></div>
          <img
            src="{{ featuredPost.data.image if featuredPost.data.image[0] == '/' else '/images/' + featuredPost.data.image }}"
            alt="{{ featuredPost.data.imageAlt }}"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="object-position: {{ featuredPost.data.imagePosition }}"
          />
          <span class="absolute top-4 left-4 z-20 {{ featuredBadgeClass }} font-label-lg text-label-lg uppercase rounded-full px-3 py-0.5">
            {{ featuredPost.data.category }}
          </span>
        </div>
        <div class="p-6 md:p-8 flex flex-col justify-center">
          <p class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-3">{{ featuredPost.date | readableDate }}</p>
          <h3 class="font-headline-lg text-headline-lg text-on-background mb-4 group-hover:text-primary transition-colors">
            {{ featuredPost.data.title }}
          </h3>
          <p class="font-body-md text-body-md text-slate-600 leading-relaxed mb-6">
            {{ featuredPost.data.description }}
          </p>
          <span class="inline-flex items-center gap-2 text-primary font-medium text-sm group-hover:gap-3 transition-all">
            Read article
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </span>
        </div>
      </div>
    </a>
  </section>

  <!-- POST GRID -->
  <section class="max-w-7xl mx-auto px-6 pb-xl">
    <h2 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-6">More Posts</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">

      {% for post in collections.posts %}
      {% if loop.index0 > 0 %}

      {% if post.data.category in ["Coaching", "News", "Parenting & Sport", "Mindset"] %}
        {% set badgeClass = "bg-primary text-on-primary" %}
      {% else %}
        {% set badgeClass = "bg-secondary text-white" %}
      {% endif %}

      <a href="{{ post.url }}"
         class="post-card block rounded-xl overflow-hidden bg-white shadow-sm border border-slate-100 group flex flex-col">
        <div class="relative h-48 overflow-hidden">
          <div class="absolute inset-0 bg-slate-900/20 z-10"></div>
          <img
            src="{{ post.data.image if post.data.image[0] == '/' else '/images/' + post.data.image }}"
            alt="{{ post.data.imageAlt }}"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            style="object-position: {{ post.data.imagePosition }}"
          />
          <span class="absolute top-3 left-3 z-20 {{ badgeClass }} font-label-lg text-label-lg uppercase rounded-full px-3 py-0.5 text-xs">
            {{ post.data.category }}
          </span>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <p class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider text-xs mb-2">{{ post.date | readableDate }}</p>
          <h3 class="font-headline-md text-headline-md text-on-background mb-3 group-hover:text-primary transition-colors leading-snug">
            {{ post.data.title }}
          </h3>
          <p class="font-body-md text-body-md text-slate-600 text-sm leading-relaxed mb-4 flex-grow">
            {{ post.data.description }}
          </p>
          <span class="inline-flex items-center gap-1.5 text-primary font-medium text-sm group-hover:gap-2.5 transition-all">
            Read more <span class="material-symbols-outlined text-base">arrow_forward</span>
          </span>
        </div>
      </a>

      {% endif %}
      {% endfor %}

      <!-- CTA card -->
      <div class="rounded-xl overflow-hidden bg-primary flex flex-col items-center justify-center p-8 text-center">
        <span class="material-symbols-outlined text-white text-5xl mb-4">sports_basketball</span>
        <h3 class="font-headline-md text-headline-md text-white mb-3">Ready to play?</h3>
        <p class="font-body-md text-body-md text-white/80 mb-6 text-sm leading-relaxed">
          Stop reading — come and see what ProBall is all about. Book a free trial session today.
        </p>
        <a href="/how-to-join.html"
           class="inline-block bg-white text-primary font-button text-button px-6 py-2.5 rounded-full hover:scale-105 active:scale-95 transition-all shadow-sm">
          Book a Free Trial
        </a>
      </div>

    </div>
  </section>
  {% endif %}

  <!-- NEWSLETTER STRIP -->
  <section class="bg-secondary text-white">
    <div class="max-w-7xl mx-auto px-6 py-md">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h3 class="font-headline-md text-headline-md text-white mb-1">Get new posts in your inbox</h3>
          <p class="font-body-md text-body-md text-white/70">Coaching tips, season news, and player development insights.</p>
        </div>
        <div class="flex gap-2 w-full md:w-auto md:min-w-96">
          <input
            type="email"
            placeholder="Your email address"
            class="bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white text-sm focus:ring-2 focus:ring-white/50 w-full placeholder-white/50 outline-none"
          />
          <button class="bg-primary text-on-primary px-5 py-3 rounded-lg font-button hover:bg-primary-container transition-colors flex-shrink-0">
            Subscribe
          </button>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- FOOTER -->
<footer class="bg-slate-900 border-t-4 border-primary w-full py-12 mt-auto">
  <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-3 gap-12">
    <div class="flex flex-col">
      <div class="bg-white rounded-lg px-3 py-2 inline-block self-start mb-4"><img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-8 w-auto object-contain"/></div>
      <p class="font-body-md text-sm text-slate-300 mb-6 leading-relaxed">Developing the next generation of Australian basketball talent through elite coaching, structured development, and a love for the game.</p>
      <div class="flex space-x-3">
        <a href="http://www.facebook.com/proballaustralia" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-primary transition-colors" aria-label="ProBall on Facebook"><svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href="https://www.instagram.com/proball_basketball/" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-white hover:bg-primary transition-colors" aria-label="ProBall on Instagram"><svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-8">
      <div>
        <h5 class="text-white font-bold mb-6 uppercase tracking-wider text-xs">Quick Links</h5>
        <ul class="space-y-4">
          <li><a href="/locations.html"  class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Programs &amp; Locations</a></li>
          <li><a href="/schedule.html"   class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Schedule</a></li>
          <li><a href="/blog/index.html" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/how-to-join.html" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">How to Join</a></li>
          <li><a href="/team.html"       class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Our Team</a></li>
        </ul>
      </div>
      <div>
        <h5 class="text-white font-bold mb-6 uppercase tracking-wider text-xs">Contact</h5>
        <ul class="space-y-4">
          <li><a href="tel:0406974582" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">0406 974 582</a></li>
          <li><a href="mailto:info@proball.com" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">info@proball.com</a></li>
          <li><a href="/terms.html" class="font-body-md text-sm text-slate-400 hover:text-primary transition-colors">Terms &amp; Conditions</a></li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col">
      <h5 class="text-white font-bold mb-6 uppercase tracking-wider text-xs">Stay in the Loop</h5>
      <p class="font-body-md text-sm text-slate-300 mb-4 leading-relaxed">Get trial dates, season openings, and coaching tips straight to your inbox.</p>
      <div class="flex gap-2">
        <input type="email" placeholder="Email address" class="bg-slate-800 border-none rounded-lg px-4 py-3 text-white text-sm focus:ring-2 focus:ring-primary w-full placeholder-slate-500 outline-none"/>
        <button class="bg-primary text-on-primary p-3 rounded-lg hover:bg-primary-container transition-colors flex-shrink-0"><span class="material-symbols-outlined">send</span></button>
      </div>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-8 mt-12 pt-8 border-t border-slate-800 text-center">
    <p class="font-body-md text-xs text-slate-500">© 2025 ProBall. All rights reserved. Sydney's youth basketball program.</p>
  </div>
</footer>

</body>
</html>
