<body class="bg-background text-on-background min-h-screen flex flex-col">

<!-- NAV -->
<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="/index.html" class="flex-shrink-0">
      <img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-12 w-auto object-contain"/>
    </a>
    <div class="hidden md:flex flex-1 items-center justify-center space-x-8">
      <a href="/index.html"       class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="/locations.html"   class="text-primary font-bold border-b-2 border-primary pb-0.5">Programs & Locations</a>
      <a href="/schedule.html"    class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="/blog/index.html"  class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Blog</a>
    </div>
    <div class="flex items-center gap-sm">
      <a href="tel:0406974582" class="hidden sm:inline-flex items-center gap-1 text-tertiary hover:text-primary font-body-md text-sm font-medium transition-colors" aria-label="Call ProBall">
        <span class="material-symbols-outlined text-base">call</span>
        0406 974 582
      </a>
      <a href="/how-to-join.html#register" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">
        Book a Free Trial
      </a>
      <button id="nav-toggle" class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors" aria-label="Open menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="/index.html"       class="block text-slate-600 font-medium hover:text-primary">Home</a>
    <a href="/locations.html"   class="block text-primary font-bold">Programs & Locations</a>
    <a href="/schedule.html"    class="block text-slate-600 font-medium hover:text-primary">Schedule</a>
    <a href="/blog/index.html"  class="block text-slate-600 font-medium hover:text-primary">Blog</a>
  </div>
</header>

<main class="flex-grow">

  <!-- HERO -->
  <section class="relative py-10 md:py-14 flex items-center overflow-hidden bg-[#004aad]">
    <div class="relative z-20 max-w-7xl mx-auto px-6 w-full">
      <div class="max-w-2xl">
        <h1 class="font-display-lg text-[32px] sm:text-[40px] md:text-display-lg text-white uppercase leading-[0.95] mb-4">
          Our Training Centres
        </h1>
        <p class="font-body-lg text-body-lg text-slate-200">
          {{ collections.locations.length }} venues across Inner Sydney and the Eastern Suburbs. Find the program and location that works for you.
        </p>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="max-w-7xl mx-auto px-6 pt-4 pb-xl lg:py-xl">
    <!-- Mobile tab strip -->
    <div class="lg:hidden sticky top-[72px] bg-background z-40 -mx-6 border-b border-slate-200 mb-6">
      <div class="flex">
        <button class="mobile-tab active flex-1 py-3 text-center font-label-lg text-label-lg uppercase text-primary border-b-2 border-primary" onclick="switchTab('miniball', this)">Miniball</button>
        <button class="mobile-tab flex-1 py-3 text-center font-label-lg text-label-lg uppercase text-tertiary border-b-2 border-transparent" onclick="switchTab('academy', this)">Academy</button>
        <button class="mobile-tab flex-1 py-3 text-center font-label-lg text-label-lg uppercase text-tertiary border-b-2 border-transparent" onclick="switchTab('teams', this)">Teams</button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter items-start">

      <!-- SIDEBAR -->
      <div class="hidden lg:block lg:col-span-4 lg:sticky lg:top-24 space-y-gutter">
        <h2 class="font-headline-lg text-headline-lg mb-base">Select Program</h2>

        <button
          class="program-tab active w-full text-left bg-surface rounded-xl border-l-4 border-primary p-6 hover:shadow-md transition-all"
          onclick="switchTab('miniball', this)">
          <div class="flex items-center gap-base mb-sm">
            <span class="material-symbols-outlined text-primary">sports_basketball</span>
            <span class="bg-slate-100 text-secondary px-3 py-1 rounded-full font-label-lg text-label-lg uppercase">Ages 5–10</span>
          </div>
          <h3 class="tab-title font-headline-md text-headline-md text-primary mb-base">Miniball</h3>
          <p class="font-body-md text-body-md text-tertiary">
            Our flagship learn-to-play program — designed to give new players the skills and knowledge to play in a team.
          </p>
        </button>

        <button
          class="program-tab w-full text-left bg-surface rounded-xl border-l-4 border-surface-variant p-6 hover:shadow-md transition-all"
          onclick="switchTab('academy', this)">
          <div class="flex items-center gap-base mb-sm">
            <span class="material-symbols-outlined text-secondary">school</span>
            <span class="bg-slate-100 text-secondary px-3 py-1 rounded-full font-label-lg text-label-lg uppercase">Ages 5–15</span>
          </div>
          <h3 class="tab-title font-headline-md text-headline-md text-on-background mb-base">The Academy</h3>
          <p class="font-body-md text-body-md text-tertiary">
            6 specialised class types. Nationally certified coaches. Available 7 days a week across {{ collections.academyLocations.length }} Sydney venues.
          </p>
        </button>

        <button
          class="program-tab w-full text-left bg-surface rounded-xl border-l-4 border-surface-variant p-6 hover:shadow-md transition-all"
          onclick="switchTab('teams', this)">
          <div class="flex items-center gap-base mb-sm">
            <span class="material-symbols-outlined text-on-background">trophy</span>
            <span class="bg-slate-100 text-secondary px-3 py-1 rounded-full font-label-lg text-label-lg uppercase">Ages 5–15</span>
          </div>
          <h3 class="tab-title font-headline-md text-headline-md text-on-background mb-base">Teams</h3>
          <p class="font-body-md text-body-md text-tertiary">
            Weekly competition. Represent ProBall. Professional coaching for training and match day.
          </p>
        </button>

        <div class="bg-secondary text-white rounded-xl p-6 mt-2">
          <p class="font-label-lg text-label-lg uppercase mb-2">Not sure which to pick?</p>
          <p class="font-body-md text-body-md text-white/80 mb-4">Call us and we'll find the right program for your child.</p>
          <a href="tel:0406974582" class="flex items-center gap-2 font-button text-button hover:text-secondary-fixed transition-colors">
            <span class="material-symbols-outlined">call</span>
            0406 974 582
          </a>
        </div>
      </div>

      <!-- LOCATION CARDS -->
      <div class="lg:col-span-8">

        <!-- MINIBALL TAB -->
        <div id="tab-miniball" class="tab-content active space-y-gutter">

          <div class="flex justify-between items-end border-b-2 border-slate-100 pb-base mb-md">
            <div>
              <h2 class="font-headline-lg text-headline-lg">Miniball Venues</h2>
              <p class="font-body-md text-body-md text-tertiary mt-1">{{ collections.miniballLocations.length }} locations · Weekends during school term</p>
            </div>
          </div>

          <div class="bg-primary-fixed rounded-xl p-6 mb-2">
            <h4 class="font-label-lg text-label-lg text-primary uppercase mb-3">About Miniball</h4>
            <p class="font-body-md text-body-md text-on-background">
              Our flagship learn-to-play program — designed to give new players the skills and knowledge to play in a team. Weekly 40-minute games during school terms (excluding long weekends). Friends can request to be placed on the same team. Limited spots — first 4 weeks are free for new members.
            </p>
          </div>

          {% for loc in collections.miniballLocations %}
          <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 group">
            <div class="grid md:grid-cols-2">
              <div class="h-56 md:h-auto overflow-hidden bg-surface-container-high flex items-center justify-center">
                {% if loc.data.heroImage %}
                <img
                  src="{{ loc.data.heroImage }}"
                  alt="{{ loc.data.heroImageAlt or loc.data.title }}"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                {% else %}
                <span class="material-symbols-outlined text-6xl text-slate-400">sports_basketball</span>
                {% endif %}
              </div>
              <div class="p-8">
                <h3 class="font-headline-md text-headline-md mb-md">{{ loc.data.title }}</h3>
                <div class="space-y-sm text-tertiary mb-lg">
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
                    <span class="font-body-md text-body-md">{{ loc.data.venueAddress }}, {{ loc.data.region }}</span>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">schedule</span>
                    <span class="font-body-md text-body-md">{{ loc.data.miniballSchedule }}</span>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">event</span>
                    <span class="font-body-md text-body-md">School terms only</span>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">group</span>
                    <span class="font-body-md text-body-md">{{ loc.data.miniballAges }}</span>
                  </div>
                </div>
                <div class="flex gap-2">
                  <a href="/how-to-join.html#register" class="flex-1 block text-center bg-primary text-on-primary font-button py-3 rounded-lg hover:bg-primary-container transition-colors">
                    Book a Free Trial
                  </a>
                  <a href="{{ loc.data.mapsUrl }}" target="_blank" rel="noopener"
                     class="flex items-center gap-1 px-4 py-3 border-2 border-secondary text-secondary rounded-lg font-button hover:bg-secondary hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-base">map</span>
                    Map
                  </a>
                </div>
                <a href="{{ loc.url }}" class="mt-3 block text-center font-label-lg text-xs font-semibold text-on-background hover:text-primary hover:underline">View full program details →</a>
              </div>
            </div>
          </div>
          {% endfor %}

        </div>

        <!-- ACADEMY TAB -->
        <div id="tab-academy" class="tab-content space-y-gutter">

          <div class="flex justify-between items-end border-b-2 border-slate-100 pb-base mb-md">
            <div>
              <h2 class="font-headline-lg text-headline-lg">Academy Venues</h2>
              <p class="font-body-md text-body-md text-tertiary mt-1">{{ collections.academyLocations.length }} locations · 7 days a week</p>
            </div>
          </div>

          <div class="bg-secondary-fixed rounded-xl p-6 mb-2">
            <h4 class="font-label-lg text-label-lg text-secondary uppercase mb-4">6 Specialised Class Types</h4>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              <div class="bg-white rounded-lg p-3 border-l-4 border-primary">
                <p class="font-label-lg text-label-lg text-primary uppercase mb-1">Splash</p>
                <p class="font-body-md text-xs text-tertiary">Shooting range &amp; knockdown accuracy</p>
              </div>
              <div class="bg-white rounded-lg p-3 border-l-4 border-secondary">
                <p class="font-label-lg text-label-lg text-secondary uppercase mb-1">Handles</p>
                <p class="font-body-md text-xs text-tertiary">Ball handling &amp; breaking defenders</p>
              </div>
              <div class="bg-white rounded-lg p-3 border-l-4 border-primary">
                <p class="font-label-lg text-label-lg text-primary uppercase mb-1">Hot Sauce</p>
                <p class="font-body-md text-xs text-tertiary">1v1, floaters, pull-ups &amp; layups</p>
              </div>
              <div class="bg-white rounded-lg p-3 border-l-4 border-secondary">
                <p class="font-label-lg text-label-lg text-secondary uppercase mb-1">Showtime</p>
                <p class="font-body-md text-xs text-tertiary">5v5 game strategy &amp; team concepts</p>
              </div>
              <div class="bg-white rounded-lg p-3 border-l-4 border-primary">
                <p class="font-label-lg text-label-lg text-primary uppercase mb-1">Shooting School</p>
                <p class="font-body-md text-xs text-tertiary">Form, technique &amp; consistent shot mechanics</p>
              </div>
              <div class="bg-white rounded-lg p-3 border-l-4 border-secondary flex items-center justify-center">
                <p class="font-label-lg text-label-lg text-secondary uppercase">+ More</p>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-gutter">
            {% for loc in collections.academyLocations %}
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:border-primary transition-all group">
              <div class="flex items-start gap-3 mb-3">
                <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
                <h4 class="font-headline-md text-headline-md group-hover:text-primary transition-colors">{{ loc.data.title }}</h4>
              </div>
              <p class="font-body-md text-body-md text-tertiary mb-1">{{ loc.data.venueAddress }}, {{ loc.data.venueCity }}</p>
              <p class="font-label-lg text-label-lg text-secondary uppercase mt-3 mb-2">
                Academy{% if 'miniball' in loc.data.programs %} &amp; Miniball{% endif %} · All Levels
              </p>
              <div class="flex items-center gap-3">
                <a href="{{ loc.data.mapsUrl }}" target="_blank" rel="noopener" class="flex items-center gap-1 font-label-lg text-xs text-primary hover:underline">
                  <span class="material-symbols-outlined text-sm">map</span>Directions
                </a>
                <a href="{{ loc.url }}" class="font-label-lg text-xs font-semibold text-on-background hover:text-primary hover:underline">View Details →</a>
              </div>
            </div>
            {% endfor %}
          </div>

          <div class="bg-surface-container rounded-xl p-6 flex flex-col md:flex-row items-center justify-between gap-4">
            <p class="font-body-md text-body-md text-on-background">Session times vary by venue. View the full weekly schedule to find a time that works for you.</p>
            <a href="/schedule.html" class="flex-shrink-0 flex items-center gap-2 bg-secondary text-on-secondary px-6 py-3 rounded-lg font-button text-button hover:opacity-90 transition-opacity">
              <span class="material-symbols-outlined">calendar_month</span>
              View Schedule
            </a>
          </div>

        </div>

        <!-- TEAMS TAB -->
        <div id="tab-teams" class="tab-content space-y-gutter">

          <div class="border-b-2 border-slate-100 pb-base mb-md">
            <h2 class="font-headline-lg text-headline-lg">Competition Basketball — Alexandria</h2>
            <p class="font-body-md text-body-md text-tertiary mt-1">City of Sydney Basketball Association · Weekly competition</p>
          </div>

          <div class="bg-[#004aad] text-white rounded-xl overflow-hidden shadow-xl">
            <div class="grid md:grid-cols-2">
              <div class="h-56 md:h-auto overflow-hidden">
                <img
                  src="/images/b098042a-9587-40d8-b0db-e0e486eb015e.jpeg"
                  alt="ProBall competition basketball Alexandria"
                  class="w-full h-full object-cover opacity-80"
                />
              </div>
              <div class="p-8">
                <div class="inline-block bg-primary text-on-primary font-label-lg text-label-lg uppercase rounded-full px-4 py-1 mb-4">
                  Play. Compete. Represent ProBall.
                </div>
                <h3 class="font-headline-md text-headline-md mb-md">Alexandria</h3>
                <div class="space-y-sm text-slate-300 mb-lg">
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
                    <a href="https://share.google/LpNIPWD9yoow0qTEZ" target="_blank" rel="noopener"
                       class="font-body-md text-body-md hover:text-primary transition-colors flex items-center gap-1">
                      Alexandria, Sydney NSW <span class="material-symbols-outlined text-sm">open_in_new</span>
                    </a>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">emoji_events</span>
                    <span class="font-body-md text-body-md">City of Sydney Basketball Association competition</span>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">group</span>
                    <span class="font-body-md text-body-md">Ages 5–15 · All experience levels welcome</span>
                  </div>
                  <div class="flex items-start gap-base">
                    <span class="material-symbols-outlined text-primary mt-0.5">school</span>
                    <span class="font-body-md text-body-md">Academy access included for all team members</span>
                  </div>
                </div>
                <a href="/how-to-join.html#register"
                   class="block text-center bg-primary text-on-primary font-button py-3 rounded-lg hover:bg-primary-container transition-colors">
                  Register Your Interest
                </a>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-8">
            <h4 class="font-headline-md text-headline-md mb-6">What Competition Basketball Provides</h4>
