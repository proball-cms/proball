<script>
  document.getElementById('nav-toggle').addEventListener('click', function () {
    document.getElementById('mobile-menu').classList.toggle('open');
  });

  function switchTab(tabId, el) {
    document.querySelectorAll('.tab-content').forEach(function (t) { t.classList.remove('active'); });
    document.querySelectorAll('.program-tab').forEach(function (t) {
      t.classList.remove('active');
      t.style.borderLeftColor = '';
    });
    document.querySelectorAll('.mobile-tab').forEach(function (t) {
      t.classList.remove('active');
      t.style.borderBottomColor = '';
      t.classList.remove('text-primary');
      t.classList.add('text-tertiary');
    });
    document.getElementById('tab-' + tabId).classList.add('active');
    el.classList.add('active');
    el.classList.remove('text-tertiary');
    el.classList.add('text-primary');
    if (window.innerWidth < 1024) {
      document.getElementById('tab-' + tabId).scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
</script>

