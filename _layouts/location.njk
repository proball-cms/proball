<body class="bg-background text-on-background min-h-screen flex flex-col">

<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="relative flex items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="/index.html" class="flex-shrink-0"><img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-12 w-auto object-contain"/></a>
    <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center space-x-8">
      <a href="/index.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="/locations.html" class="text-primary font-bold border-b-2 border-primary pb-0.5">Programs &amp; Locations</a>
      <a href="/schedule.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="/blog/index.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Blog</a>
    </div>
    <div class="ml-auto flex items-center gap-sm">
      <a href="/how-to-join.html#register" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">Book a Free Trial</a>
      <button id="nav-toggle" class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors" aria-label="Open menu"><span class="material-symbols-outlined">menu</span></button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="/index.html" class="block text-slate-600 font-medium hover:text-primary">Home</a>
    <a href="/locations.html" class="block text-primary font-bold">Programs &amp; Locations</a>
    <a href="/schedule.html" class="block text-slate-600 font-medium hover:text-primary">Schedule</a>
    <a href="/blog/index.html" class="block text-slate-600 font-medium hover:text-primary">Blog</a>
  </div>
</header>

<main class="flex-grow">

  <!-- HERO -->
  <section class="relative h-56 md:h-72 flex items-end overflow-hidden bg-[#004aad]">
    <div class="absolute inset-0 z-0">
      {% if heroImage %}
      <div class="absolute inset-0 bg-gradient-to-t from-[#004aad] via-[#004aad]/60 to-[#004aad]/20 z-10"></div>
      <img src="{{ heroImage }}" alt="{{ heroImageAlt }}" class="w-full h-full object-cover"/>
      {% else %}
      <div class="absolute inset-0 bg-gradient-to-t from-[#004aad] to-[#002b6f] z-0"></div>
      {% endif %}
    </div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 w-full pb-10">
      <a href="/locations.html" class="inline-flex items-center gap-1 text-white/60 text-xs hover:text-white mb-4 transition-colors"><span class="material-symbols-outlined text-sm">arrow_back</span> All Locations</a>
      <span class="inline-block bg-primary text-white text-xs font-semibold uppercase tracking-wider rounded-full px-3 py-0.5 mb-3">{{ region }}</span>
      <h1 class="font-headline-lg text-headline-lg text-white max-w-3xl leading-tight">Basketball Classes for Kids in {{ title }}</h1>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-6 py-xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- Main content -->
      <div class="lg:col-span-8 space-y-10">

        <!-- About -->
        <section>
          <h2 class="font-headline-md text-headline-md mb-4">About the Program</h2>
          {% for para in aboutParagraphs %}
            {% if loop.first %}
              <p class="font-body-lg text-body-lg text-tertiary mb-4">{{ para | markdown | safe }}</p>
            {% else %}
              <p class="font-body-md text-body-md text-tertiary mb-4">{{ para | markdown | safe }}</p>
            {% endif %}
          {% endfor %}
        </section>

        <!-- Location & Sessions -->
        <section>
          <h2 class="font-headline-md text-headline-md mb-4">Location &amp; Sessions</h2>
          <div class="bg-surface rounded-xl p-6 space-y-4">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary mt-0.5">location_on</span>
              <div>
                <p class="font-body-md text-body-md font-semibold">{{ venueAddress }}</p>
                <p class="font-body-md text-body-md text-tertiary">{{ venueCity }}</p>
                <a href="{{ mapsUrl }}" target="_blank" rel="noopener" class="text-primary text-sm hover:underline mt-1 inline-block">Get directions →</a>
              </div>
            </div>
            {% if 'miniball' in programs %}
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary mt-0.5">schedule</span>
              <div>
                <p class="font-body-md text-body-md font-semibold">Miniball — {{ miniballSchedule }}</p>
                <p class="font-body-md text-body-md text-tertiary">School terms only · {{ miniballAges }}</p>
              </div>
            </div>
            {% endif %}
            {% if 'academy' in programs %}
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary mt-0.5">school</span>
              <div>
                <p class="font-body-md text-body-md font-semibold">Academy — {{ academySchedule }}</p>
                <p class="font-body-md text-body-md text-tertiary">{{ academyAges }}</p>
              </div>
            </div>
            {% endif %}
          </div>
        </section>

        <!-- Programs at this venue -->
        <section>
          <h2 class="font-headline-md text-headline-md mb-4">Programs at This Venue</h2>
          {% if 'miniball' in programs and 'academy' in programs %}
          <div class="grid md:grid-cols-2 gap-gutter">
            <div class="bg-white rounded-xl shadow-sm border-l-4 border-primary p-6">
              <h3 class="font-headline-md text-headline-md mb-2">Miniball</h3>
              <p class="font-label-lg text-label-lg text-secondary uppercase mb-3">Ages 5–10 · {{ miniballSchedule | replace("·", "·") | truncate(20, true, "") }}s</p>
              <p class="font-body-md text-body-md text-tertiary">Weekly 40-minute modified games during school terms. No scorekeeping, no pressure — just fun basketball with friends. First 4 weeks are free for new members.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm border-l-4 border-secondary p-6">
              <h3 class="font-headline-md text-headline-md mb-2">Academy</h3>
              <p class="font-label-lg text-label-lg text-secondary uppercase mb-3">Ages 5–15 · 7 days a week</p>
              <p class="font-body-md text-body-md text-tertiary">Structured skills sessions with nationally certified coaches. Six specialised class types covering shooting, ball handling, 1v1, game strategy and more.</p>
            </div>
          </div>
          {% elif 'miniball' in programs %}
          <div class="bg-white rounded-xl shadow-sm border-l-4 border-primary p-6 max-w-md">
            <h3 class="font-headline-md text-headline-md mb-2">Miniball</h3>
            <p class="font-label-lg text-label-lg text-secondary uppercase mb-3">Ages 5–10 · Weekends</p>
            <p class="font-body-md text-body-md text-tertiary">Weekly 40-minute modified games during school terms. No scorekeeping, no pressure. First 4 weeks free for new members.</p>
          </div>
          {% else %}
          <div class="bg-white rounded-xl shadow-sm border-l-4 border-secondary p-6 max-w-md">
            <h3 class="font-headline-md text-headline-md mb-2">Academy</h3>
            <p class="font-label-lg text-label-lg text-secondary uppercase mb-3">Ages 5–15 · 7 days a week</p>
            <p class="font-body-md text-body-md text-tertiary">Structured skills training with nationally certified coaches. Six specialised class types covering every aspect of the game, from shooting and ball handling to team strategy and 1v1 play.</p>
          </div>
          {% endif %}
        </section>

        <!-- Why families choose -->
        <section>
          <h2 class="font-headline-md text-headline-md mb-4">Why Families Choose ProBall {{ title }}</h2>
          <ul class="space-y-3">
            {% for item in whyChoose %}
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary mt-0.5 flex-shrink-0">check_circle</span>
              <p class="font-body-md text-body-md text-tertiary">{{ item }}</p>
            </li>
            {% endfor %}
          </ul>
        </section>

        <!-- Nearby suburbs -->
        <section class="bg-primary-fixed rounded-xl p-6">
          <h2 class="font-headline-md text-headline-md mb-3">{{ nearbySuburbsHeading }}</h2>
          <p class="font-body-md text-body-md text-tertiary mb-3">{{ nearbySuburbsIntro }}</p>
          <div class="flex flex-wrap gap-2">
            {% for suburb in nearbySuburbs %}
            <span class="bg-white text-on-background px-3 py-1 rounded-full text-sm font-medium">{{ suburb }}</span>
            {% endfor %}
          </div>
        </section>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 lg:sticky lg:top-28 space-y-6">
        <div class="bg-primary rounded-2xl p-6 text-white text-center">
          <span class="material-symbols-outlined text-3xl mb-3 block">sports_basketball</span>
          <h3 class="font-headline-md text-headline-md mb-2">Book a Free Trial</h3>
          <p class="text-white/80 text-sm mb-4">{{ sidebarTrialText }}</p>
          <a href="/how-to-join.html#register" class="inline-block bg-white text-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 transition-all">Get Started</a>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
          <h3 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-4">Other Locations</h3>
          <div class="space-y-3">
            {% for loc in collections.locations | sort(false, false, 'data.order') %}
              {% if loc.url !== page.url %}
              <a href="{{ loc.url }}" class="block text-sm font-medium text-on-background hover:text-primary transition-colors">{{ loc.data.title }} ({{ loc.data.region }}) →</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
          <h3 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-3">Contact Us</h3>
          <a href="tel:0406974582" class="flex items-center gap-2 text-sm text-on-background hover:text-primary transition-colors mb-2"><span class="material-symbols-outlined text-sm">call</span>0406 974 582</a>
          <a href="mailto:info@proball.com" class="flex items-center gap-2 text-sm text-on-background hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">mail</span>info@proball.com</a>
        </div>
      </aside>

    </div>
  </div>

</main>

