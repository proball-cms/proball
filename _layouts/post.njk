<body class="bg-background text-on-background min-h-screen flex flex-col">
<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="relative flex items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="/index.html" class="flex-shrink-0"><img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-12 w-auto object-contain"/></a>
    <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 items-center space-x-8">
      <a href="/index.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="/locations.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Programs &amp; Locations</a>
      <a href="/schedule.html" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="/blog/index.html" class="text-primary font-bold border-b-2 border-primary pb-0.5">Blog</a>
    </div>
    <div class="ml-auto flex items-center gap-sm">
      <a href="/how-to-join.html#register" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">Book a Free Trial</a>
      <button id="nav-toggle" class="md:hidden p-2 text-slate-600 hover:text-primary"><span class="material-symbols-outlined">menu</span></button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="/index.html" class="block text-slate-600 font-medium hover:text-primary">Home</a>
    <a href="/locations.html" class="block text-slate-600 font-medium hover:text-primary">Programs &amp; Locations</a>
    <a href="/schedule.html" class="block text-slate-600 font-medium hover:text-primary">Schedule</a>
    <a href="/blog/index.html" class="block text-primary font-bold">Blog</a>
  </div>
</header>
<script>document.getElementById('nav-toggle').addEventListener('click',function(){document.getElementById('mobile-menu').classList.toggle('open');});</script>

<main class="flex-grow">
  <div class="relative min-h-56 md:min-h-64 flex items-center overflow-hidden bg-[#004aad] py-10">
    {% if image %}
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-t from-[#004aad]/80 via-[#004aad]/60 to-[#004aad]/40 z-10"></div>
      <img src="{{ image if image[0] == '/' else '/images/' + image }}" alt="{{ imageAlt }}" class="w-full h-full object-cover" style="object-position: {{ imagePosition or 'center center' }}"/>
    </div>
    {% endif %}
    <div class="relative z-20 max-w-7xl mx-auto px-6 w-full">
      <a href="/blog/index.html" class="inline-flex items-center gap-1 text-white/60 text-xs hover:text-white mb-4 transition-colors"><span class="material-symbols-outlined text-sm">arrow_back</span> Blog</a>
      {% set categoryClass %}{% if category in ["Coaching", "News", "Parenting & Sport", "Mindset"] %}bg-primary text-white{% else %}bg-secondary text-white{% endif %}{% endset %}
      <span class="inline-block {{ categoryClass }} text-xs font-semibold uppercase tracking-wider rounded-full px-3 py-0.5 mb-3">{{ category }}</span>
      <h1 class="font-headline-lg text-headline-lg text-white max-w-3xl leading-tight">{{ title }}</h1>
      <p class="text-slate-300 text-sm mt-3">{{ date | readableDate }} &nbsp;·&nbsp; {{ author }}</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-xl">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <article class="lg:col-span-8 prose-blog bg-white rounded-2xl shadow-sm border border-slate-100 p-8 md:p-12">

        {{ content | safe }}

        <div class="mt-12 pt-8 border-t border-slate-100">
          <div class="bg-primary/5 border border-primary/20 rounded-xl p-6">
            <h3 class="font-headline-md text-headline-md text-on-background mb-2">{{ ctaHeading }}</h3>
            <p class="text-slate-600 text-sm mb-4">{{ ctaBody }}</p>
            <a href="/how-to-join.html#register" class="inline-block bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 transition-all">Book a Free Trial</a>
          </div>
        </div>
      </article>

      <aside class="lg:col-span-4 lg:sticky lg:top-28 space-y-6">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
          <h3 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-4">Written by</h3>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-primary">person</span></div>
            <div><p class="font-medium text-on-background text-sm">{{ author }}</p><p class="text-slate-400 text-xs">{{ authorTitle }}</p></div>
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
          <h3 class="font-label-lg text-label-lg text-slate-400 uppercase tracking-wider mb-4">More from the blog</h3>
          <div class="space-y-4">
            {% set otherPosts = collections.posts | exclude(page.url) | limit(5) %}
            {% for post in otherPosts %}
            <a href="{{ post.url }}" class="block group">
              <p class="text-sm font-medium text-on-background group-hover:text-primary transition-colors leading-snug">{{ post.data.title }}</p>
              <p class="text-xs text-slate-400 mt-0.5">{{ post.date | readableDate }}</p>
            </a>
            {% endfor %}
          </div>
        </div>
        <div class="bg-primary rounded-2xl p-6 text-white text-center">
          <span class="material-symbols-outlined text-3xl mb-3 block">sports_basketball</span>
          <h3 class="font-headline-md text-headline-md mb-2">Free trial</h3>
          <p class="text-white/80 text-sm mb-4">Come and see what ProBall is all about.</p>
          <a href="/how-to-join.html#register" class="inline-block bg-white text-primary px-5 py-2 rounded-full font-medium text-sm hover:scale-105 transition-all">Book Now</a>
        </div>
      </aside>
    </div>
    <div class="mt-12 pt-8 border-t border-slate-200"><a href="/blog/index.html" class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all text-sm"><span class="material-symbols-outlined text-lg">arrow_back</span> Back to blog</a></div>
  </div>
</main>

