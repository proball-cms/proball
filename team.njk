<body class="bg-background text-on-background min-h-screen flex flex-col">

<header class="bg-white border-b-2 border-slate-100 shadow-sm sticky top-0 z-50">
  <nav class="flex justify-between items-center w-full px-6 py-3 max-w-7xl mx-auto">
    <a href="index.html" class="flex-shrink-0">
      <img src="https://ik.imagekit.io/xckefgqnh/wp-content/uploads/2025/04/ProBall_Logo.jpg" alt="ProBall" class="h-12 w-auto object-contain"/>
    </a>
    <div class="hidden md:flex items-center space-x-8">
      <a href="index.html"       class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Home</a>
      <a href="locations.html"   class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Programs &amp; Locations</a>
      <a href="schedule.html"    class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Schedule</a>
      <a href="team.html"        class="text-primary font-bold border-b-2 border-primary pb-0.5">Our Team</a>
      <a href="blog/index.html"  class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">Blog</a>
      <a href="how-to-join.html#register" class="text-slate-600 font-medium hover:text-primary transition-colors duration-200">How to Join</a>
    </div>
    <div class="flex items-center gap-sm">
      <a href="how-to-join.html#register" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-button text-button hover:scale-105 active:scale-95 transition-all shadow-sm">
        Book a Free Trial
      </a>
      <button id="nav-toggle" class="md:hidden p-2 text-slate-600 hover:text-primary transition-colors" aria-label="Open menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
  <div id="mobile-menu" class="md:hidden bg-white border-t border-slate-100 px-6 py-4 space-y-4">
    <a href="index.html"       class="block text-slate-600 font-medium hover:text-primary">Home</a>
    <a href="locations.html"   class="block text-slate-600 font-medium hover:text-primary">Programs &amp; Locations</a>
    <a href="schedule.html"    class="block text-slate-600 font-medium hover:text-primary">Schedule</a>
    <a href="team.html"        class="block text-primary font-bold">Our Team</a>
    <a href="blog/index.html"  class="block text-slate-600 font-medium hover:text-primary">Blog</a>
    <a href="how-to-join.html#register" class="block text-slate-600 font-medium hover:text-primary">How to Join</a>
  </div>
</header>

<main class="flex-grow">

  <section class="relative py-6 md:py-14 flex items-center overflow-hidden bg-[#004aad]">
    <div class="max-w-7xl mx-auto px-6 w-full">
      <span class="inline-block py-1 px-4 bg-primary text-on-primary font-label-lg text-label-lg tracking-widest uppercase rounded-full mb-3 md:mb-6">The Brains</span>
      <h1 class="font-display-lg text-[32px] sm:text-[44px] md:text-display-lg text-white uppercase leading-[0.95] mb-2 md:mb-4">The ProBall Team</h1>
      <p class="font-body-md md:font-body-lg text-body-md md:text-body-lg text-slate-300 max-w-xl">
        Over 100 years of combined basketball experience. Built in Sydney. Devoted to developing the next generation.
      </p>
    </div>
  </section>

  <section class="py-8 md:py-xl">
    <div class="max-w-7xl mx-auto px-6 space-y-8 md:space-y-16">

      {% for member in collections.team | sort(false, false, 'data.order') %}
      {% set isOdd = loop.index % 2 === 1 %}

      <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="grid md:grid-cols-5">

          {% if isOdd %}
          <!-- Photo (left for odd) -->
          <div class="md:col-span-2 {{ member.data.photoBg }} min-h-44 md:min-h-0 relative overflow-hidden flex items-end">
            <div class="absolute inset-0 bg-gradient-to-t from-{{ member.data.photoBg | replace('bg-', '') }}/80 to-transparent z-10"></div>
            <img
              src="{{ member.data.photo }}"
              alt="{{ member.data.name }}"
              class="absolute inset-0 w-full h-full object-cover {{ member.data.photoObjectPosition }} {{ member.data.photoOpacity }}"
            />
            <div class="relative z-20 p-4 md:p-6">
              {% set nameParts = member.data.name.split(' ') %}
              <p class="font-display-lg text-2xl md:text-3xl font-black text-white uppercase leading-tight">{{ nameParts[0] }}<br/>{{ nameParts[1] }}</p>
              <p class="font-label-lg text-label-lg text-{{ member.data.roleColor }} uppercase mt-1">{{ member.data.role }}</p>
            </div>
          </div>
          <!-- Content (right for odd) -->
          <div class="md:col-span-3 p-5 md:p-12">
          {% else %}
          <!-- Content (left for even) -->
          <div class="md:col-span-3 p-5 md:p-12 md:order-1 order-2">
          {% endif %}

            <div class="flex items-center justify-between mb-6">
              <div>
                <h2 class="font-headline-lg text-headline-lg">{{ member.data.name }}</h2>
                <p class="font-label-lg text-label-lg text-{{ member.data.roleColor }} uppercase mt-1">{{ member.data.role }}</p>
              </div>
              {% if member.data.linkedinUrl %}
              <a href="{{ member.data.linkedinUrl }}" target="_blank" rel="noopener"
                 class="flex items-center gap-2 text-secondary hover:text-primary transition-colors font-label-lg text-label-lg">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              {% endif %}
            </div>
            <p class="font-body-lg text-body-lg text-on-background leading-relaxed mb-6">{{ member.data.bioMain | markdown | safe }}</p>
            <p class="font-body-md text-body-md text-tertiary leading-relaxed mb-6">{{ member.data.bioSub | markdown | safe }}</p>
            <div class="flex flex-wrap gap-2">
              {% for cred in member.data.credentials %}
              <span class="bg-{{ member.data.credentialColor }}-fixed text-{{ member.data.credentialColor }} font-label-lg text-label-lg px-3 py-1 rounded-full uppercase">{{ cred }}</span>
              {% endfor %}
            </div>
          </div>

          {% if not isOdd %}
          <!-- Photo (right for even) -->
          <div class="md:col-span-2 {{ member.data.photoBg }} min-h-44 md:min-h-0 relative overflow-hidden flex items-end md:order-2 order-1">
            <div class="absolute inset-0 bg-gradient-to-t from-{{ member.data.photoBg | replace('bg-', '') }}/80 to-transparent z-10"></div>
            <img
              src="{{ member.data.photo }}"
              alt="{{ member.data.name }}"
              class="absolute inset-0 w-full h-full object-cover {{ member.data.photoObjectPosition }} {{ member.data.photoOpacity }}"
            />
            <div class="relative z-20 p-4 md:p-6">
              {% set nameParts = member.data.name.split(' ') %}
              <p class="font-display-lg text-2xl md:text-3xl font-black text-white uppercase leading-tight">{{ nameParts[0] }}<br/>{{ nameParts[1] }}</p>
              <p class="font-label-lg text-label-lg text-{% if member.data.roleColor == 'secondary' %}secondary-fixed-dim{% else %}{{ member.data.roleColor }}{% endif %} uppercase mt-1">{{ member.data.role }}</p>
            </div>
          </div>
          {% endif %}

        </div>
      </div>

      {% endfor %}

    </div>
  </section>

  <section class="bg-[#004aad] py-lg">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="font-display-lg text-display-lg text-primary mb-1">100+</div>
        <div class="font-label-lg text-label-lg text-slate-400 uppercase">Years Combined Experience</div>
      </div>
      <div>
        <div class="font-display-lg text-display-lg text-primary mb-1">1982</div>
        <div class="font-label-lg text-label-lg text-slate-400 uppercase">ProBall Founded</div>
      </div>
      <div>
        <div class="font-display-lg text-display-lg text-primary mb-1">624</div>
        <div class="font-label-lg text-label-lg text-slate-400 uppercase">Wins by Rex Nottage</div>
      </div>
      <div>
        <div class="font-display-lg text-display-lg text-primary mb-1">🥈</div>
        <div class="font-label-lg text-label-lg text-slate-400 uppercase">2012 Paralympics</div>
      </div>
    </div>
  </section>

  <section class="py-xl bg-primary-container relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
      <h2 class="font-display-lg text-display-lg text-white mb-6 uppercase leading-[0.95]">Train With the Best</h2>
      <p class="font-body-lg text-body-lg text-on-primary-container/90 mb-10 max-w-2xl mx-auto">
        This is the team coaching your child. Book a free trial and experience the ProBall difference firsthand.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="how-to-join.html#register" class="bg-white text-primary px-10 py-5 rounded-lg font-button text-button shadow-xl hover:scale-105 active:scale-95 transition-all">Book a Free Trial</a>
        <a href="schedule.html" class="bg-transparent border-2 border-white text-white px-10 py-5 rounded-lg font-button text-button hover:bg-white/10 transition-all">View Schedule</a>
      </div>
    </div>
  </section>

</main>

